{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetBucketLocation"],
      "Resource": ["arn:aws:s3:::su-mbhg-hostgen"]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": ["arn:aws:s3:::su-mbhg-hostgen"],
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "users/",
            "users/*",
            "shared/",
            "shared/*",
            "users/devon/",
            "users/devon/*",
            "shared/devon/",
            "shared/devon/*"
          ]
        }
      }
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": ["arn:aws:s3:::su-mbhg-hostgen/shared/*"]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:AbortMultipartUpload", "s3:ListMultipartUploadParts"],
      "Resource": [
        "arn:aws:s3:::su-mbhg-hostgen/users/devon/*",
        "arn:aws:s3:::su-mbhg-hostgen/shared/devon/*"
      ]
    }
  ]
}
