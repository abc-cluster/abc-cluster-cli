{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetBucketLocation"],
      "Resource": ["arn:aws:s3:::su-psy-neuropsychiatry"]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": ["arn:aws:s3:::su-psy-neuropsychiatry"],
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "users/",
            "users/*",
            "shared/",
            "shared/*",
            "users/lauren/",
            "users/lauren/*",
            "shared/lauren/",
            "shared/lauren/*"
          ]
        }
      }
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": ["arn:aws:s3:::su-psy-neuropsychiatry/shared/*"]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:AbortMultipartUpload", "s3:ListMultipartUploadParts"],
      "Resource": [
        "arn:aws:s3:::su-psy-neuropsychiatry/users/lauren/*",
        "arn:aws:s3:::su-psy-neuropsychiatry/shared/lauren/*"
      ]
    }
  ]
}
