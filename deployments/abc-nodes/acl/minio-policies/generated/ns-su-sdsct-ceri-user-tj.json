{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetBucketLocation"],
      "Resource": ["arn:aws:s3:::su-sdsct-ceri"]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": ["arn:aws:s3:::su-sdsct-ceri"],
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "users/",
            "users/*",
            "shared/",
            "shared/*",
            "users/tj/",
            "users/tj/*",
            "shared/tj/",
            "shared/tj/*"
          ]
        }
      }
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": ["arn:aws:s3:::su-sdsct-ceri/shared/*"]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:AbortMultipartUpload", "s3:ListMultipartUploadParts"],
      "Resource": [
        "arn:aws:s3:::su-sdsct-ceri/users/tj/*",
        "arn:aws:s3:::su-sdsct-ceri/shared/tj/*"
      ]
    }
  ]
}
