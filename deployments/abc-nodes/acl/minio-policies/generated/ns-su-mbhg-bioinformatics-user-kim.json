{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetBucketLocation"],
      "Resource": ["arn:aws:s3:::su-mbhg-bioinformatics"]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": ["arn:aws:s3:::su-mbhg-bioinformatics"],
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "users/",
            "users/*",
            "shared/",
            "shared/*",
            "users/kim/",
            "users/kim/*",
            "shared/kim/",
            "shared/kim/*"
          ]
        }
      }
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": ["arn:aws:s3:::su-mbhg-bioinformatics/shared/*"]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:AbortMultipartUpload", "s3:ListMultipartUploadParts"],
      "Resource": [
        "arn:aws:s3:::su-mbhg-bioinformatics/users/kim/*",
        "arn:aws:s3:::su-mbhg-bioinformatics/shared/kim/*"
      ]
    }
  ]
}
