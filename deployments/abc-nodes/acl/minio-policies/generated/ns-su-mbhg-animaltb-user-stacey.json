{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetBucketLocation"],
      "Resource": ["arn:aws:s3:::su-mbhg-animaltb"]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": ["arn:aws:s3:::su-mbhg-animaltb"],
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "users/",
            "users/*",
            "shared/",
            "shared/*",
            "users/stacey/",
            "users/stacey/*",
            "shared/stacey/",
            "shared/stacey/*"
          ]
        }
      }
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": ["arn:aws:s3:::su-mbhg-animaltb/shared/*"]
    },
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:AbortMultipartUpload", "s3:ListMultipartUploadParts"],
      "Resource": [
        "arn:aws:s3:::su-mbhg-animaltb/users/stacey/*",
        "arn:aws:s3:::su-mbhg-animaltb/shared/stacey/*"
      ]
    }
  ]
}
