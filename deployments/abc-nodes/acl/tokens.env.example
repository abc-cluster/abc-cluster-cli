# Nomad ACL tokens — generated by apply-su-mbhg.sh
# Convention: token Name == MinIO username; token SecretID == MinIO secret key
# Copy to tokens.env (chmod 600) and fill in real values, OR run apply-su-mbhg.sh
# to generate fresh tokens and populate this file automatically.
#
# DO NOT COMMIT tokens.env

# Management token (bootstrap — store in Vault: secret/abc-nodes/nomad/management-token)
export NOMAD_MGMT_TOKEN=<bootstrap-management-token>

# SU-MBHG Bioinformatics
export NOMAD_TOKEN_BIO_SUBMIT=<uuid>  # su-mbhg-bioinformatics_submit
export NOMAD_TOKEN_BIO_ADMIN=<uuid>   # su-mbhg-bioinformatics_admin
export NOMAD_TOKEN_BIO_ALICE=<uuid>   # su-mbhg-bioinformatics_alice

# SU-MBHG Host Genetics
export NOMAD_TOKEN_HG_SUBMIT=<uuid>   # su-mbhg-hostgen_submit
export NOMAD_TOKEN_HG_ADMIN=<uuid>    # su-mbhg-hostgen_admin
export NOMAD_TOKEN_HG_BOB=<uuid>      # su-mbhg-hostgen_bob
