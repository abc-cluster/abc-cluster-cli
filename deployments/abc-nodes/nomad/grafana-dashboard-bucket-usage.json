{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Bucket usage characteristics for MinIO namespaces (capacity, object counts, request volume). Requires MinIO metrics to be scraped into Prometheus.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              }
            ]
          },
          "unit": "string"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "left",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {
            "uid": "prometheus"
          },
          "expr": "vector(1)",
          "legendFormat": "If this dashboard is empty, add MinIO scrape targets (e.g., /minio/v2/metrics/cluster) to Prometheus."
        }
      ],
      "title": "Prerequisite",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "uid": "prometheus"
          },
          "expr": "sum by (bucket) (minio_bucket_usage_total_bytes{bucket=~\"$bucket\"})",
          "legendFormat": "{{bucket}}"
        }
      ],
      "title": "Bucket Size by Namespace",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "uid": "prometheus"
          },
          "expr": "sum by (bucket) (minio_bucket_usage_object_total{bucket=~\"$bucket\"})",
          "legendFormat": "{{bucket}}"
        }
      ],
      "title": "Object Count by Bucket",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "uid": "prometheus"
          },
          "expr": "sum by (bucket) (minio_bucket_usage_version_total{bucket=~\"$bucket\"})",
          "legendFormat": "{{bucket}} versions"
        },
        {
          "datasource": {
            "uid": "prometheus"
          },
          "expr": "sum by (bucket) (minio_bucket_usage_deletemarker_total{bucket=~\"$bucket\"})",
          "legendFormat": "{{bucket}} delete-markers"
        }
      ],
      "title": "Versioning & Delete Markers by Bucket",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "uid": "prometheus"
          },
          "expr": "sum by (bucket, range) (minio_bucket_objects_size_distribution{bucket=~\"$bucket\"})",
          "legendFormat": "{{bucket}} {{range}}"
        }
      ],
      "title": "Object Size Distribution by Bucket",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "abc-nodes",
    "minio",
    "bucket-usage"
  ],
  "templating": {
    "list": [
      {
        "name": "bucket",
        "label": "Bucket",
        "type": "custom",
        "query": "su-mbhg-animaltb,su-mbhg-bioinformatics,su-mbhg-hostgen,su-mbhg-tbgenomics,su-psy-neuropsychiatry,su-sdsct-ceri",
        "options": [],
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "abc-nodes Bucket Usage",
  "uid": "abc-nodes-bucket-usage",
  "version": 6
}
