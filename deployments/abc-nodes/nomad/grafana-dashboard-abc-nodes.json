{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [
    {
      "builtIn": 1,
      "datasource": { "type": "grafana", "uid": "-- Grafana --" },
      "enable": true,
      "hide": true,
      "iconColor": "rgba(0, 211, 255, 1)",
      "name": "Annotations & Alerts",
      "type": "dashboard"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "enable": true,
      "expr": "changes(nomad_nomad_job_status_running[1m]) > 0",
      "hide": false,
      "iconColor": "green",
      "name": "Job state changes",
      "step": "60s",
      "titleFormat": "job event"
    }
  ]},
  "description": "abc-nodes cluster monitoring: Nomad jobs, node resources, alloc metrics, group/user fairness, and logs",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Cluster Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "Down" }, "1": { "color": "green", "text": "Up" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Nomad Client Alive",
      "type": "stat",
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "min(nomad_client_uptime) > 0", "legendFormat": "client" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Autopilot Healthy",
      "type": "stat",
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "nomad_nomad_autopilot_healthy", "legendFormat": "autopilot" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Running Jobs",
      "type": "stat",
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "nomad_nomad_job_status_running", "legendFormat": "running" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Failed Jobs",
      "type": "stat",
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "nomad_nomad_job_status_dead", "legendFormat": "dead/failed" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Heartbeats",
      "type": "stat",
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "nomad_nomad_heartbeat_active", "legendFormat": "heartbeats" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Client Uptime",
      "type": "stat",
      "targets": [{ "datasource": { "uid": "prometheus" }, "expr": "min(nomad_client_uptime)", "legendFormat": "uptime" }]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Node Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "MHz", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "CPU — Allocated vs Unallocated",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_client_allocated_cpu{host=~\"$node\"}", "legendFormat": "allocated {{host}}" },
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_client_unallocated_cpu{host=~\"$node\"}", "legendFormat": "unallocated {{host}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Memory — Allocated vs Unallocated",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_client_allocated_memory{host=~\"$node\"}", "legendFormat": "allocated {{host}}" },
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_client_unallocated_memory{host=~\"$node\"}", "legendFormat": "unallocated {{host}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "id": 12,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Host Memory — Available",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "node_memory_MemAvailable_bytes", "legendFormat": "available {{instance}}" },
        { "datasource": { "uid": "prometheus" }, "expr": "node_memory_MemTotal_bytes", "legendFormat": "total {{instance}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "id": 13,
      "options": { "legend": { "calcs": ["lastNotNull", "mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Host CPU Usage by Mode",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "rate(node_cpu_seconds_total{mode!=\"idle\"}[2m])", "legendFormat": "{{mode}} {{cpu}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "Bps", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 20 },
      "id": 14,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Disk I/O",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "rate(node_disk_read_bytes_total[2m])", "legendFormat": "read {{device}}" },
        { "datasource": { "uid": "prometheus" }, "expr": "rate(node_disk_written_bytes_total[2m])", "legendFormat": "write {{device}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "Bps", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 20 },
      "id": 15,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Network I/O",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*\"}[2m])", "legendFormat": "rx {{device}}" },
        { "datasource": { "uid": "prometheus" }, "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*\"}[2m])", "legendFormat": "tx {{device}}" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 102,
      "title": "Job & Allocation Status (all namespaces)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 28 },
      "id": 20,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Job Summary — Task Group Counts",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_nomad_job_summary_running{namespace=~\"$namespace\"}", "legendFormat": "running {{namespace}}/{{exported_job}}" },
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_nomad_job_summary_complete{namespace=~\"$namespace\"}", "legendFormat": "complete {{namespace}}/{{exported_job}}" },
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_nomad_job_summary_failed{namespace=~\"$namespace\"}", "legendFormat": "failed {{namespace}}/{{exported_job}}" },
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_nomad_job_summary_queued{namespace=~\"$namespace\"}", "legendFormat": "queued {{namespace}}/{{exported_job}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 28 },
      "id": 21,
      "options": { "legend": { "calcs": ["lastNotNull", "mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Alloc CPU Usage %",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_client_allocs_cpu_total_percent{namespace=~\"$namespace\",exported_job=~\"$job\"} / 100", "legendFormat": "{{namespace}}/{{exported_job}}/{{task}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 35 },
      "id": 22,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Alloc Memory RSS",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_client_allocs_memory_rss{namespace=~\"$namespace\",exported_job=~\"$job\"}", "legendFormat": "{{namespace}}/{{exported_job}}/{{task}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 35 },
      "id": 23,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Alloc Memory Usage",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_client_allocs_memory_usage{namespace=~\"$namespace\",exported_job=~\"$job\"}", "legendFormat": "{{namespace}}/{{exported_job}}/{{task}}" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "id": 105,
      "title": "Group Fairness — Resource Share by Namespace",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "CPU MHz currently allocated per research group namespace. A dominant slice means that group is monopolising the cluster.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "MHz", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 43 },
      "id": 50,
      "options": {
        "displayLabels": ["name", "value"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value"] },
        "pieType": "donut",
        "tooltip": { "mode": "single" }
      },
      "title": "CPU Share by Group (now)",
      "type": "piechart",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "sum by (namespace) (nomad_client_allocs_cpu_allocated_mhz)", "legendFormat": "{{namespace}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Memory (MB) currently allocated per research group namespace.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "mbytes", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 43 },
      "id": 51,
      "options": {
        "displayLabels": ["name", "value"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value"] },
        "pieType": "donut",
        "tooltip": { "mode": "single" }
      },
      "title": "Memory Share by Group (now)",
      "type": "piechart",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "sum by (namespace) (nomad_client_allocs_memory_allocated) / 1048576", "legendFormat": "{{namespace}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of running task group allocations per namespace. Imbalance signals group monopolisation.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 43 },
      "id": 52,
      "options": {
        "displayLabels": ["name", "value"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value"] },
        "pieType": "donut",
        "tooltip": { "mode": "single" }
      },
      "title": "Running Allocations by Group (now)",
      "type": "piechart",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "sum by (namespace) (nomad_nomad_job_summary_running)", "legendFormat": "{{namespace}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "CPU usage trend per namespace over time — reveals if one group is consistently crowding others.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "MHz", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 50 },
      "id": 53,
      "options": { "legend": { "calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "CPU Allocation Trend by Group",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "sum by (namespace) (nomad_client_allocs_cpu_allocated_mhz)", "legendFormat": "{{namespace}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Memory allocation trend per namespace over time.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "mbytes", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 50 },
      "id": 54,
      "options": { "legend": { "calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Memory Allocation Trend by Group",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "sum by (namespace) (nomad_client_allocs_memory_allocated) / 1048576", "legendFormat": "{{namespace}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Queued allocations per namespace — a persistent queue means that group cannot schedule and may be starving the others.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 57 },
      "id": 55,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Queued Allocations by Group (scheduler pressure)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "sum by (namespace) (nomad_nomad_job_summary_queued)", "legendFormat": "{{namespace}} queued" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Preempted allocations — Nomad has evicted lower-priority jobs to make room. Non-zero means fairness enforcement is working.",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 57 },
      "id": 56,
      "options": { "legend": { "calcs": ["lastNotNull", "sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Preempted Allocations (fairness enforcement)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "increase(nomad_nomad_plan_preemption_eval_count[5m])", "legendFormat": "preemptions/5m" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 64 },
      "id": 106,
      "title": "Per-Group Job Detail — $namespace",
      "type": "row",
      "repeat": "namespace",
      "repeatDirection": "h"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 65 },
      "id": 60,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Jobs in $namespace",
      "type": "timeseries",
      "repeatByVariable": "namespace",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_nomad_job_summary_running{namespace=\"$namespace\"}", "legendFormat": "running {{exported_job}}" },
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_nomad_job_summary_failed{namespace=\"$namespace\"}", "legendFormat": "failed {{exported_job}}" },
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_nomad_job_summary_queued{namespace=\"$namespace\"}", "legendFormat": "queued {{exported_job}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 65 },
      "id": 61,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "CPU % by Task in $namespace",
      "type": "timeseries",
      "repeatByVariable": "namespace",
      "targets": [
        { "datasource": { "uid": "prometheus" }, "expr": "nomad_client_allocs_cpu_total_percent{namespace=\"$namespace\"} / 100", "legendFormat": "{{exported_job}}/{{task}}" }
      ]
    },
    {
