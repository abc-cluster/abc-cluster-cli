          "expr": "clamp_max(sum by (namespace) (nomad_client_allocs_cpu_total_percent{nomad_role!=\"nomad\", namespace=~\"su-.*\", exported_job=~\"$job\"}) / (sum by (namespace) (nomad_client_allocs_cpu_allocated{nomad_role!=\"nomad\", namespace=~\"su-.*\", exported_job=~\"$job\"}) / 100), 1)",
          "legendFormat": "{{namespace}} cpu efficiency"
        }
      ],
      "title": "CPU Allocation Efficiency (Higher is better)",
