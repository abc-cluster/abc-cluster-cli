      "description": "Heuristic ratio of summed alloc CPU percent to summed reserved CPU (Nomad `nomad_client_allocs_cpu_allocated`, MHz). Uses `/100` scaling in the denominator only to keep values in a comparable range; clamped to 1.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
