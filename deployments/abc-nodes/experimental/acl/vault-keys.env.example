# Copy to vault-keys.env (same directory). That file is gitignored.
# Populate by running: bash deployments/abc-nodes/experimental/scripts/init-vault.sh
#
# VAULT_ROOT_TOKEN is a HashiCorp Vault token (sensitive). Do not paste real values into the repo.

export VAULT_ADDR=http://127.0.0.1:8200
export VAULT_ROOT_TOKEN=<paste-root-token-from-init-output>
export VAULT_UNSEAL_KEY_1=<unseal-key-1>
export VAULT_UNSEAL_KEY_2=<unseal-key-2>
export VAULT_UNSEAL_KEY_3=<unseal-key-3>
export VAULT_UNSEAL_KEY_4=<unseal-key-4>
export VAULT_UNSEAL_KEY_5=<unseal-key-5>
